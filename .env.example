# =========================================================
# Laviolette App — environment variables (template)
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; never commit real secrets.
# =========================================================

# ----- Frontend (browser-exposed via Vite) -----
# These are safe to ship in the client bundle because RLS
# protects the database.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ----- Backend scripts only (never VITE_*, never committed) -----
# Used by scripts/create-auth-user.mjs and local admin tasks.
# Do NOT reference these from any file under src/.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_DB_PASSWORD=your-db-password-here
SUPABASE_PROJECT_REF=your-project-ref-here

# ----- Stripe (CLI script only) -----
# Used by scripts/stripe-setup.js for ACH bank collection.
# In production, the Edge Function reads STRIPE_SECRET_KEY
# from a Supabase Edge Function secret (set via the dashboard),
# not from this file.
STRIPE_SECRET_KEY=sk_live_your_key_here
STRIPE_RESTRICTED_KEY=rk_live_your_restricted_key_here

# ----- Resend (Phase 4 reminder emails) -----
# Set in Supabase Edge Function secrets for production;
# this env var is only used when testing send-reminders locally.
RESEND_API_KEY=re_your_key_here
